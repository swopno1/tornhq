generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String               @id @default(cuid())
  email                   String?              @unique
  passwordHash            String?
  emailVerified           DateTime?
  emailVerificationToken  String?              @unique
  emailVerificationExpiry DateTime?
  tornId                  Int?                 @unique
  apiKeyEnc               String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  snapshots               StatSnapshot[]
  alerts                  Alert[]
  watchedItems            WatchedItem[]
  passwordResetTokens     PasswordResetToken[]
  slotsJobs               SlotsJob[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model StatSnapshot {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strength  Int
  defense   Int
  speed     Int
  dexterity Int
  total     Int
  level     Int
  xp        Int
  takenAt   DateTime @default(now())

  @@index([userId, takenAt])
}

model MarketItem {
  id           String        @id @default(cuid())
  tornItemId   Int           @unique
  name         String
  category     String
  priceHistory PricePoint[]
  watchers     WatchedItem[]
  updatedAt    DateTime      @updatedAt
}

model PricePoint {
  id           String     @id @default(cuid())
  itemId       String
  item         MarketItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  averagePrice Int
  lowestPrice  Int
  volume       Int
  recordedAt   DateTime   @default(now())

  @@index([itemId, recordedAt])
}

model WatchedItem {
  userId     String
  itemId     String
  alertBelow Int?
  alertAbove Int?
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  item       MarketItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
}

model Alert {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AlertType
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

enum AlertType {
  energy_ready
  nerve_ready
  travel_landed
  chain_alert
  price_alert
  cooldown_expired
}

model SlotsJob {
  id                 String         @id @default(cuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  betAmount          Int
  intervalSecs       Int
  totalRuns          Int
  minBalance         Int            @default(0)
  isRecurring        Boolean        @default(false)
  runHourUtc         Int?
  strategy           String         @default("FIXED")
  strategyMultiplier Float          @default(2.0)
  strategyMaxSteps   Int            @default(3)
  currentBet         Int?
  completedRuns      Int            @default(0)
  totalWon           Int            @default(0)
  totalBet           Int            @default(0)
  startingBalance    Int?
  lastBalance        Int?
  lastScheduledAt    DateTime?
  status             SlotsJobStatus @default(PENDING)
  lastRunAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  logs               SlotsSpinLog[]

  @@index([userId, status])
  @@index([isRecurring, runHourUtc])
}

model SlotsSpinLog {
  id            String   @id @default(cuid())
  jobId         String
  job           SlotsJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  betAmount     Int
  won           Int
  balanceBefore Int?
  result        Json
  spunAt        DateTime @default(now())

  @@index([jobId, spunAt])
}

enum SlotsJobStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}
